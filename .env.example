# Database
# PENSION_DATA_DATABASE_URL=sqlite:///./.pension-data/pension_data.db

# LLM Provider
# PENSION_DATA_LLM_PROVIDER=openai
# PENSION_DATA_OPENAI_MODEL=gpt-4o-mini
# PENSION_DATA_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# LangSmith Tracing (optional)
# LANGSMITH_API_KEY=
# LANGCHAIN_PROJECT=pension-data
# PENSION_DATA_LANGSMITH_TRACE_TESTS=false

# NL Log Path (optional)
# PENSION_DATA_NL_LOG_PATH=

# Deployment (optional)
# PENSION_DATA_API_BASE_URL=
# PENSION_DATA_ARTIFACT_BASE_URL=
# PENSION_DATA_ENVIRONMENT_LABEL=local
